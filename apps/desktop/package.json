{
  "name": "mycodex-desktop",
  "private": true,
  "version": "0.1.14",
  "description": "Desktop shell for pairing with a local or remote MyCodex server",
  "license": "MIT",
  "homepage": "https://github.com/LeoGray/mycodex",
  "repository": {
    "type": "git",
